{
  "name": "@badhope/trae-skills",
  "version": "1.0.0",
  "type": "module",
  "description": "Trae IDE Official Skills Marketplace - The Extension Marketplace for AI-Powered Development",
  "main": "./dist/packages/core/index.js",
  "types": "./dist/packages/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/core/index.js",
      "types": "./dist/packages/core/index.d.ts"
    },
    "./mcp/*": {
      "import": "./dist/mcp/*/index.js",
      "types": "./dist/mcp/*/index.d.ts"
    },
    "./builder": {
      "import": "./dist/packages/core/mcp/builder.js",
      "types": "./dist/packages/core/mcp/builder.d.ts"
    }
  },
  "bin": {
    "trae-skill": "./packages/cli/index.js"
  },
  "files": [
    "dist/",
    "packages/cli/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "skill:list": "node packages/cli/index.js mcp",
    "skill:tools": "node packages/cli/index.js mcp-tools",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/trae-skills.git"
  },
  "keywords": [
    "trae",
    "trae-extension",
    "trae-skill",
    "mcp",
    "model-context-protocol",
    "ide",
    "skills",
    "ai",
    "llm",
    "agent"
  ],
  "trae": {
    "type": "mcp-skill",
    "version": "1.0.0",
    "entrypoint": "packages/cli/index.js",
    "marketplace": {
      "categories": ["Development", "Code Quality", "Workflow"],
      "featured": true,
      "official": true,
      "badges": ["Editor's Pick", "Productivity"]
    },
    "mcpServers": {
      "git": "mcp/git/index.ts",
      "terminal": "mcp/terminal/index.ts",
      "code-review": "mcp/code-review/index.ts",
      "test-generator": "mcp/test-generator/index.ts",
      "documentation": "mcp/documentation/index.ts",
      "search": "mcp/search/index.ts",
      "code-generator": "mcp/code-generator/index.ts",
      "dependency-analyzer": "mcp/dependency-analyzer/index.ts",
      "react": "mcp/react/index.ts",
      "typescript": "mcp/typescript/index.ts",
      "docker": "mcp/docker/index.ts",
      "security-auditor": "mcp/security-auditor/index.ts",
      "performance-optimizer": "mcp/performance-optimizer/index.ts",
      "coding-workflow": "mcp/coding-workflow/index.ts",
      "debugging-workflow": "mcp/debugging-workflow/index.ts",
      "refactoring-workflow": "mcp/refactoring-workflow/index.ts"
    }
  },
  "author": "Trae Skills Team",
  "license": "Apache-2.0",
  "homepage": "https://skills.trae.dev",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "zod": "^3.22.4",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0",
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "trae": {
    "skills": [
      "code-review",
      "bug-fixer",
      "test-generator",
      "explain-this",
      "refactor-this",
      "doc-generator",
      "architect"
    ]
  }
}

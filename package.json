{
  "name": "skills",
  "version": "3.1.0",
  "type": "module",
  "description": "MCP Mega-Agent Platform - 13 Expert Engines + 96+ Professional Tools for ALL LLMs",
  "main": "./dist/packages/core/index.js",
  "types": "./dist/packages/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/core/index.js",
      "types": "./dist/packages/core/index.d.ts"
    },
    "./mcp/*": {
      "import": "./dist/mcp/*/index.js",
      "types": "./dist/mcp/*/index.d.ts"
    },
    "./builder": {
      "import": "./dist/packages/core/mcp/builder.js",
      "types": "./dist/packages/core/mcp/builder.d.ts"
    }
  },
  "bin": {
    "skills": "./packages/cli/index.js"
  },
  "files": [
    "dist/",
    "packages/cli/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "skill:list": "node packages/cli/index.js mcp",
    "skill:tools": "node packages/cli/index.js mcp-tools",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },

{
  "name": "@devflow-agent/core",
  "version": "1.0.0",
  "type": "module",
  "description": "DevFlow Agent - Development Workflow Agent with 7 core skills and 16 workflows for AI platforms",
  "main": "./dist/packages/core/index.js",
  "types": "./dist/packages/core/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/core/index.js",
      "types": "./dist/packages/core/index.d.ts"
    },
    "./skills/*": {
      "import": "./dist/packages/core/skill/skills/*.js",
      "types": "./dist/packages/core/skill/skills/*.d.ts"
    }
  },
  "bin": {
    "devflow": "./packages/cli/index.js"
  },
  "files": [
    "dist/",
    "packages/cli/",
    "packages/core/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "js-yaml": "^4.1.0",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/js-yaml": "^4.0.9",
    "@types/archiver": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/badhope/devflow-agent.git"
  },
  "keywords": [
    "devflow",
    "devflow-agent",
    "development-workflow",
    "ai-agent",
    "automation",
    "productivity",
    "workflow",
    "developer-tools",
    "claude",
    "cursor",
    "windsurf",
    "doubao",
    "trae",
    "agent",
    "development",
    "programming"
  ],
  "author": "badhope",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/badhope/devflow-agent/issues"
  },
  "homepage": "https://github.com/badhope/devflow-agent#readme"
}
